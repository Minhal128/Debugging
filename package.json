    "axios": "^1.4.0",
    "chart.js": "^4.4.7",
    "env-cmd": "^10.1.0",
    "lucide-react": "^0.475.0",
    "moment": "^2.30.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.4.0",
    "react-redux": "^8.1.2",
    "react-router-dom": "^6.15.0",
    "react-structure": "file:",
    "react-toastify": "^9.1.3",
